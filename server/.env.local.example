# ShopERP Pro — Local/Hosted Server Environment (server/local.js)
# ─────────────────────────────────────────────────────────────────
# This is the ACTUAL production entry point (`npm run start:local` /
# `node local.js`) — the SQLite-backed server used by both the Local WiFi
# deployment and the web/hosted SaaS registration flow. Copy this file to
# server/.env and fill in real values. NEVER commit server/.env itself
# (it's gitignored) — placeholders only belong in this .example file.
#
# See docs/deployment/EnvironmentSetup.md for what each variable does and
# how to generate safe values.
#
# Note: server/.env.example (no ".local") documents a DIFFERENT, mostly
# vestigial Postgres/cloud entry point (server/index.js), not this one —
# see that file's own header before using it.

# ── Required — the server refuses to boot without these ──────────────────

# Signs both access and refresh tokens. Changing it logs out every active
# session everywhere. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING

# SMTP — required as of the SaaS licensing/registration system. Used only to
# send the registration email-verification link (POST /api/auth/signup).
# The server exits at boot with a [FATAL] message if any of these five are
# missing — this affects every deployment of this file, even ones not using
# self-service registration yet.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme@example.com
SMTP_PASS=changeme
SMTP_FROM=ShopERP Pro <no-reply@example.com>

# ── Recommended — has a default, but you should override it ───────────────

# sha256 hash of your Super Admin password. Gates every /api/admin/* route.
# Unset falls back to a well-known default hash — fine for local dev, NOT
# for a real deployment. Generate with:
#   echo -n 'YourAdminPassword' | shasum -a 256
ADMIN_KEY=CHANGE_ME_SHA256_HASH_OF_ADMIN_PASSWORD

# ── Optional — sensible defaults if unset ──────────────────────────────────

# TCP port the server listens on. Default: 3000.
PORT=3000

# Where the SQLite database file lives. Default: server/shoperpro.db
# (next to local.js). Point this somewhere durable/backed-up in production.
DB_PATH=./shoperpro.db

# Comma-separated list of allowed CORS origins, e.g.
#   ALLOWED_ORIGINS=https://shop.example.com,https://admin.example.com
# Unset = no restriction (fine for local/dev, tighten this for a public
# production deployment).
ALLOWED_ORIGINS=

# How often (ms) the license status-transition sweep runs (ACTIVE->READ_ONLY
# ->SUSPENDED->ARCHIVED). Default: 900000 (15 minutes). You will not
# normally need to change this — it exists mainly so tests can shrink it.
LICENSE_SWEEP_INTERVAL_MS=900000

# Reserved for future use — NOT currently read by any code. Documented here
# because it was requested as part of this deployment's environment
# checklist, but wiring it up (e.g. to skip SMTP enforcement or short-circuit
# email sending) would be a business-logic change, out of scope for this
# deployment-readiness pass. SMTP is unconditionally required at boot today
# regardless of this value. Left in as a placeholder for a future toggle.
EMAIL_ENABLED=true
