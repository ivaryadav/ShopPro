# ShopERP Pro — Server Environment Config
# Copy to .env and fill in values (Cloud/PostgreSQL mode ONLY — server/index.js)
#
# This is NOT the file you want for the actual production entry point
# (server/local.js, the SQLite-backed Local WiFi / hosted SaaS server) —
# local.js requires several env vars of its own (JWT_SECRET, SMTP_*, etc.).
# See server/.env.local.example for that.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=shoperpro
DB_USER=shoperpro_user
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING

ALLOWED_ORIGIN=https://yourdomain.com
PORT=3000
NODE_ENV=production
