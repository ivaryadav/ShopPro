# ShopERP Pro — Server Environment Config
# Copy to .env and fill in values (Cloud/PostgreSQL mode only)
# Local WiFi mode (local.js) does NOT need this file

DB_HOST=localhost
DB_PORT=5432
DB_NAME=shoperpro
DB_USER=shoperpro_user
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING

ALLOWED_ORIGIN=https://yourdomain.com
PORT=3000
NODE_ENV=production
