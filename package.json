{
  "name": "shoperpro",
  "version": "1.0.0",
  "description": "ShopERP Pro - Mobile Shop Management System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis --x64",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.shoperpro.app",
    "productName": "ShopERP Pro",
    "copyright": "Copyright © 2025 ShopERP Pro",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "darkModeSupport": true,
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShopERP Pro"
    },
    "dmg": {
      "title": "ShopERP Pro",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "node-machine-id": "^1.1.12"
  }
}
